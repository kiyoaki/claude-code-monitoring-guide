{
  "title": "Claude Code - Harness Health",
  "uid": "cc-harness-health",
  "tags": ["claude-code", "harness"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Skill invocations (range)",
      "description": "Custom harness metric from skill-usage-logger. Populates from real (non-test) Skill-tool use.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(increase(claude_code_harness_skill_invocation_total[$__range])) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Hook denies (range)",
      "description": "Custom harness metric. Total guard denies in the selected range across all guards.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(increase(claude_code_harness_hook_deny_total[$__range])) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Edit accept rate (range)",
      "description": "accept / (accept + reject) for file-edit tools. A harness-quality signal: low values mean Claude's edits are frequently rejected.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "(sum(increase(claude_code_code_edit_tool_decision_total{decision=\"accept\"}[$__range])) or vector(0)) / clamp_min(sum(increase(claude_code_code_edit_tool_decision_total[$__range])) or vector(0), 1)",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Guard fail-closed errors (range)",
      "description": "Denies caused by an unhandled guard exception (kind=error), not a rule match. Any non-zero value points to a buggy guard that is blocking work.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_harness_hook_deny_total{kind=\"error\"}[$__range])) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Skill trigger rate by skill",
      "description": "Per-second invocation rate of each skill. Reveals which skills fire most and whether triggering tracks intent.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (skill) (rate(claude_code_harness_skill_invocation_total[$__rate_interval]))",
          "legendFormat": "{{skill}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Top skills (range)",
      "description": "Total invocations per skill in the selected range.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "topk(20, sum by (skill) (increase(claude_code_harness_skill_invocation_total[$__range])))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true } } },
        { "id": "sortBy", "options": { "sort": [{ "field": "Value", "desc": true }] } }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Hook deny rate by guard",
      "description": "Per-second deny rate per guard. A spike means a guard is firing often -- either catching real mistakes or being too aggressive.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (hook) (rate(claude_code_harness_hook_deny_total[$__rate_interval]))",
          "legendFormat": "{{hook}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Denies by guard and kind (range)",
      "description": "Deny counts split by guard and kind (rule vs error). Use to find which guards block the most and whether any are erroring.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum by (hook, kind) (increase(claude_code_harness_hook_deny_total[$__range]))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true } } },
        { "id": "sortBy", "options": { "sort": [{ "field": "Value", "desc": true }] } }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Edit decisions rate (accept vs reject)",
      "description": "Rate of file-edit tool accept/reject decisions. Built-in metric claude_code_code_edit_tool_decision_total.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (decision) (rate(claude_code_code_edit_tool_decision_total[$__rate_interval]))",
          "legendFormat": "{{decision}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Edit reject rate by tool",
      "description": "Reject rate per edit tool (Edit / Write / NotebookEdit). High reject volume on a tool flags where Claude's edits miss most.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (tool_name) (rate(claude_code_code_edit_tool_decision_total{decision=\"reject\"}[$__rate_interval]))",
          "legendFormat": "{{tool_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Token usage by type (cache efficiency)",
      "description": "Built-in metric. cacheRead vs input/output shows prompt-cache effectiveness.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 28 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (type) (rate(claude_code_token_usage_tokens_total[5m]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Estimated cost (USD, range)",
      "description": "Built-in local USD estimate (not billed amount on Max plan). Useful as a relative weight.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 28 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(increase(claude_code_cost_usage_USD_total[$__range])) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Sessions (range)",
      "description": "Built-in metric claude_code_session_count_total.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 28 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(increase(claude_code_session_count_total[$__range])) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ]
    }
  ]
}
