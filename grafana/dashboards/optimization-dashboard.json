{
  "title": "Claude Code - Optimization",
  "uid": "cc-optimization",
  "tags": ["claude-code", "optimization"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-7d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "MCP tool calls by server (range)",
      "description": "Which MCP servers you ACTUALLY call. A server that appears in 'MCP servers connecting' but NOT here is a prune candidate. Populates from claude_code_harness_mcp_tool_call_total after a session is started with the mcp-usage-logger hook active.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum by (server) (increase(claude_code_harness_mcp_tool_call_total[$__range]))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true } } },
        { "id": "sortBy", "options": { "sort": [{ "field": "Value", "desc": true }] } }
      ]
    },
    {
      "id": 2,
      "type": "table",
      "title": "MCP servers connecting (range)",
      "description": "Servers that connect each session (cost of being loaded). Cross-check against 'MCP tool calls by server': connected but never called = candidate to disable.",
      "datasource": { "type": "loki", "uid": "claude-code-loki" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "claude-code-loki" },
          "expr": "sum by (server_scope, transport_type, is_plugin) (count_over_time({service_name=\"claude-code\"} | event_name=\"mcp_server_connection\" | status=\"connected\" [$__range]))",
          "queryType": "instant",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "table",
      "title": "MCP connection time by scope (avg ms)",
      "description": "Average connect duration. Slow connections you rarely use are the highest-value prunes.",
      "datasource": { "type": "loki", "uid": "claude-code-loki" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "claude-code-loki" },
          "expr": "avg by (server_scope, transport_type) (avg_over_time({service_name=\"claude-code\"} | event_name=\"mcp_server_connection\" | unwrap duration_ms [$__range]))",
          "queryType": "instant",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "Native tool calls by tool (range)",
      "description": "From claude_code.tool_result. Native tools appear by real name; all MCP calls collapse into the single 'mcp_tool' row (see the MCP panels for the breakdown).",
      "datasource": { "type": "loki", "uid": "claude-code-loki" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "claude-code-loki" },
          "expr": "sum by (tool_name) (count_over_time({service_name=\"claude-code\"} | event_name=\"tool_result\" | tool_name!=\"\" [$__range]))",
          "queryType": "instant",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "MCP tool calls by specific tool (range)",
      "description": "The granular MCP usage the native telemetry can't give. Tools never listed here are loaded but unused.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum by (tool) (increase(claude_code_harness_mcp_tool_call_total[$__range]))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true } } },
        { "id": "sortBy", "options": { "sort": [{ "field": "Value", "desc": true }] } }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Hook execution time by event (avg ms)",
      "description": "From claude_code.hook_execution_complete. High SessionStart/UserPromptSubmit time points at expensive hooks worth trimming.",
      "datasource": { "type": "loki", "uid": "claude-code-loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "claude-code-loki" },
          "expr": "avg by (hook_event) (avg_over_time({service_name=\"claude-code\"} | event_name=\"hook_execution_complete\" | unwrap total_duration_ms [$__auto]))",
          "legendFormat": "{{hook_event}}",
          "queryType": "range",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Plugin hook overhead (sdk_hook_py ms)",
      "description": "From claude_code.hook_plugin_metrics. Per-plugin hook startup cost. A plugin you do not use is pure overhead here.",
      "datasource": { "type": "loki", "uid": "claude-code-loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "claude-code-loki" },
          "expr": "max by (plugin_id) (max_over_time({service_name=\"claude-code\"} | event_name=\"hook_plugin_metrics\" | unwrap sdk_hook_py [$__range]))",
          "queryType": "instant",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Skill invocations by skill (range)",
      "description": "From the custom claude_code_harness_skill_invocation_total. Skills you never invoke are candidates to drop from the load set.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum by (skill) (increase(claude_code_harness_skill_invocation_total[$__range]))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true } } },
        { "id": "sortBy", "options": { "sort": [{ "field": "Value", "desc": true }] } }
      ]
    },
    {
      "id": 9,
      "type": "table",
      "title": "Guard denies by hook (range)",
      "description": "From claude_code_harness_hook_deny_total. Which guard hooks actually fire (and whether any fire as kind=error).",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum by (hook, kind) (increase(claude_code_harness_hook_deny_total[$__range]))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true } } },
        { "id": "sortBy", "options": { "sort": [{ "field": "Value", "desc": true }] } }
      ]
    },
    {
      "id": 10,
      "type": "logs",
      "title": "MCP / hook / decision events (raw)",
      "description": "Live tail of connection, hook, and permission-decision events for ad-hoc pruning investigation.",
      "datasource": { "type": "loki", "uid": "claude-code-loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 33 },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "claude-code-loki" },
          "expr": "{service_name=\"claude-code\"} | event_name=~\"mcp_server_connection|hook_execution_complete|hook_plugin_metrics|tool_decision\"",
          "queryType": "range",
          "refId": "A"
        }
      ]
    }
  ]
}
